{
    "name": "emailverify-ai/php-sdk",
    "description": "Official EmailVerify PHP SDK for email verification",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "EmailVerify",
            "email": "support@emailverify.com"
        }
    ],
    "keywords": [
        "email",
        "verification",
        "validation",
        "emailverify",
        "email-verification"
    ],
    "homepage": "https://emailverify.com",
    "support": {
        "source": "https://github.com/emailverify-ai/php-sdk"
    },
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "EmailVerify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EmailVerify\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src"
    }
}
