{
    "name": "billionverify/php-sdk",
    "description": "Official BillionVerify PHP SDK for email verification",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BillionVerify",
            "email": "support@billionverify.com"
        }
    ],
    "keywords": [
        "email",
        "verification",
        "validation",
        "billionverify",
        "email-verification"
    ],
    "homepage": "https://billionverify.com",
    "support": {
        "source": "https://github.com/BillionVerify/php-sdk"
    },
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "BillionVerify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BillionVerify\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src"
    }
}
